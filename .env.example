# ForgeAI - Environment Configuration Reference

# 1. RENDER RECOMMENDED CONFIG (SINGLE VARIABLE)
# Use this to stay within Render's free plan environment variable limits.
# Replace values with your own and paste as a single string in Render's env var section.
APP_CONFIG={"GEMINI_API_KEY":"AIzaSy...","GITLAB_TOKEN":"glft-...","GITLAB_PROJECT_ID":123,"GITLAB_WEBHOOK_SECRET":"your-secret","AGENT_MODEL":"gemini-2.0-flash","LOG_LEVEL":"INFO"}

# 2. INDIVIDUAL VARIABLES (Optional, overridden by APP_CONFIG if present)
# Google API Key (Gemini)
# GOOGLE_API_KEY=

# GitLab Configuration
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=
# GITLAB_PROJECT_ID=
# GITLAB_WEBHOOK_SECRET=

# Redis Configuration (Optional, defaults to in-memory)
# REDIS_URL=redis://localhost:6379/0

# Agent Settings
# AGENT_MODEL=gemini-2.0-flash
# AGENT_MAX_TOKENS=8192
# AGENT_TIMEOUT_SECONDS=180
# AGENT_MAX_RETRIES=2

# Logging
# LOG_LEVEL=INFO
# ENVIRONMENT=production
